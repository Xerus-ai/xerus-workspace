{
  "version": "1.0",
  "skills": {
    "agent-creation": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "promptTriggers": {
        "keywords": ["create agent", "new agent", "clone agent", "customize agent", "agent template"],
        "intentPatterns": ["create.*agent", "clone.*agent", "new.*agent", "customize.*agent"]
      }
    },
    "knowledge-graph-maintenance": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "promptTriggers": {
        "keywords": ["knowledge graph", "entity links", "backlinks", "graph maintenance", "entity relationships"],
        "intentPatterns": ["update.*graph", "maintain.*knowledge", "link.*entities", "graph.*maintenance"]
      }
    },
    "memory-compression": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "promptTriggers": {
        "keywords": ["compress memory", "memory cleanup", "archive memory", "memory too large", "reduce memory"],
        "intentPatterns": ["compress.*memory", "cleanup.*memory", "archive.*memory", "reduce.*memory"]
      }
    },
    "sanitize-workspace": {
      "type": "system",
      "enforcement": "required",
      "priority": "critical",
      "promptTriggers": {
        "keywords": ["sanitize workspace", "validate workspace", "restore workspace", "import workspace", "workspace integrity", "fix workspace", "workspace corrupted"],
        "intentPatterns": ["sanitize.*workspace", "validate.*workspace", "restore.*backup", "import.*workspace", "fix.*workspace", "workspace.*integrity"]
      },
      "autoTriggers": {
        "events": ["workspace_restore", "workspace_import", "template_upgrade"],
        "description": "Auto-triggered by backend on S3 restore, user upload, or template version change"
      }
    },
    "housekeeping": {
      "type": "system",
      "enforcement": "suggest",
      "priority": "low",
      "promptTriggers": {
        "keywords": ["housekeeping", "clean workspace", "workspace cleanup", "check workspace", "workspace health", "tidy workspace"],
        "intentPatterns": ["clean.*workspace", "workspace.*cleanup", "housekeeping", "workspace.*health", "tidy.*workspace"]
      },
      "autoTriggers": {
        "events": ["session_end", "task_completed"],
        "description": "Suggested by session-end hook after task completion"
      }
    },
    "channel-manager": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "promptTriggers": {
        "keywords": ["standup", "channel standup", "weekly report", "team standup", "channel metrics", "OKR tracking"],
        "intentPatterns": ["channel.*standup", "weekly.*report", "team.*update", "OKR.*track"]
      }
    },
    "workspace-sync": {
      "type": "system",
      "enforcement": "suggest",
      "priority": "high",
      "promptTriggers": {
        "keywords": ["sync agents", "update agent files", "refresh workspace", "agent drift", "sync workspace"],
        "intentPatterns": ["sync.*agent", "update.*agent.*file", "refresh.*workspace", "workspace.*sync"]
      },
      "autoTriggers": {
        "events": ["skill_change", "knowledge_change", "channel_change", "roster_change"],
        "description": "Auto-triggered by workspace-sync-hook.sh on sync-relevant file changes"
      }
    },
    "data-steward": {
      "type": "domain",
      "enforcement": "required",
      "priority": "high",
      "promptTriggers": {
        "keywords": ["research", "data storage", "entity extraction", "company.db", "3-layer"],
        "intentPatterns": ["store.*data", "extract.*entit", "log.*research", "data.*ecosystem"]
      }
    }
  }
}
