# SDK local settings (user-specific)
.claude/settings.local.json

# Runtime artifacts (generated inside sandbox, not in template)
.xerus/runner/agent-runner.js
.xerus/runner/platform-mcp-server.js
.memory/.git/

# Secrets and credentials (CRITICAL — users create these in their workspaces)
.env
.env.*
.env.local
*.key
*.pem
*.p12
*.pfx
*.jks
*.secret
.secrets/
credentials.json
service-account*.json
*-firebase-adminsdk-*.json

# SQLite databases (created by scaffold, not in template)
data/company.db
data/*.db-journal
*.db-wal
*.db-shm

# Scratch files (disposable between sessions)
**/scratch/

# OS files
.DS_Store
Thumbs.db
bash.exe.stackdump

# Node
node_modules/
.npm/
.xerus/ipc/__pycache__/
