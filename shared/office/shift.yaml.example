# Shift Template Schema
# Place as shift.yaml in your channel directory:
#   projects/{domain}/channels/{channel}/shift.yaml
#
# Instantiate daily tasks via:
#   bash .claude/hooks/scripts/instantiate-shift.sh projects/{domain}/channels/{channel}
#
# The script creates a beads epic + child tasks with dependencies
# in the channel's .beads/ directory.

name: "Daily Content Shift"
cadence: daily  # daily | weekly | on-demand

# Tasks execute in dependency order.
# Tasks with no depends_on start immediately.
# Tasks with depends_on wait until all listed tasks are closed.
tasks:
  - id: research
    title: "Research trending topics"
    assignee: curator-carla          # agent slug
    priority: 1                      # 0=highest, 4=lowest
    skills: [last30days, trend-research]
    description: "Run last30days skill for the channel's focus topics. Save findings to deliverables."
    acceptance:
      deliverable: "output/deliverables/research-{date}.md"
      min_bytes: 500                 # minimum file size in bytes

  - id: draft-tweets
    title: "Draft 3 tweets from research"
    assignee: thread-theo
    priority: 2
    depends_on: [research]           # waits for research to close
    skills: [twitter-engagement, bird]
    acceptance:
      deliverable: "output/deliverables/tweets-{date}.md"
      min_bytes: 200

  - id: draft-replies
    title: "Draft 10 reply targets"
    assignee: reply-rex
    priority: 2
    depends_on: [research]           # parallel with draft-tweets
    skills: [twitter-engagement, bird]
    acceptance:
      deliverable: "output/deliverables/replies-{date}.md"
      min_bytes: 200

  - id: post-content
    title: "Post all approved content"
    assignee: thread-theo
    priority: 2
    depends_on: [draft-tweets, draft-replies]  # waits for ALL drafts
    skills: [bird]
    acceptance:
      deliverable: "output/posts.jsonl"

  - id: log-metrics
    title: "Log metrics and update context"
    assignee: growth-guru
    priority: 3
    depends_on: [post-content]
    skills: [data-steward, google-analytics]
    acceptance:
      deliverable: "context.md"
